{
  "title": "SISPARDT - Overview",
  "uid": "sispardt-overview",
  "tags": ["sispardt"],
  "timezone": "America/La_Paz",
  "refresh": "5s",
  "schemaVersion": 39,
  "time": { "from": "now-2m", "to": "now" },
  "panels": [
    {
      "id": 8,
      "title": "RAM disponible",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-sispardt" },
          "expr": "node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes * 100",
          "legendFormat": "RAM disponible %"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "id": 7,
      "title": "CPU del host",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-sispardt" },
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[30s])) * 100)",
          "legendFormat": "CPU %"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "id": 11,
      "title": "Disco del host — uso %",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-sispardt" },
          "expr": "100 - (node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"} * 100)",
          "legendFormat": "Disco usado %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": 0  },
              { "color": "yellow", "value": 70 },
              { "color": "red",    "value": 90 }
            ]
          },
          "custom": { "thresholdsStyle": { "mode": "line+area" } }
        }
      }
    },
    {
      "id": 10,
      "title": "Keycloak — autenticaciones/min",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-sispardt" },
          "expr": "rate(keycloak_credentials_password_hashing_validations_total{outcome=\"valid\",realm=\"sispardt\"}[1m])",
          "legendFormat": "Logins exitosos/min"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-sispardt" },
          "expr": "rate(keycloak_credentials_password_hashing_validations_total{outcome=\"invalid\",realm=\"sispardt\"}[1m])",
          "legendFormat": "Intentos fallidos/min"
        }
      ]
    },
    {
      "id": 12,
      "title": "Disco del host — espacio libre",
      "type": "stat",
      "gridPos": { "x": 0, "y": 12, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-sispardt" },
          "expr": "node_filesystem_avail_bytes{mountpoint=\"/\"}",
          "legendFormat": "Libre"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": 0           },
              { "color": "yellow", "value": 5368709120  },
              { "color": "green",  "value": 10737418240 }
            ]
          }
        }
      }
    },
    {
      "id": 13,
      "title": "Disco del host — total",
      "type": "stat",
      "gridPos": { "x": 6, "y": 12, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-sispardt" },
          "expr": "node_filesystem_size_bytes{mountpoint=\"/\"}",
          "legendFormat": "Total"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      }
    },
    {
      "id": 1,
      "title": "Servicios activos",
      "type": "stat",
      "gridPos": { "x": 20, "y": 12, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-sispardt" },
          "expr": "sum(up{job=~\"svc-.*\"})",
          "legendFormat": "Servicios up"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "green",  "value": 2 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Requests/segundo — API Gateway",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-sispardt" },
          "expr": "sum(rate(traefik_service_requests_total[1m])) by (service)",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Latencia p95 — requests HTTP",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-sispardt" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, job))",
          "legendFormat": "p95 {{job}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 4,
      "title": "Conexiones activas — PostgreSQL Establecimientos",
      "type": "stat",
      "gridPos": { "x": 12, "y": 12, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-sispardt" },
          "expr": "sum(pg_stat_activity_count{job=\"postgres-establecimientos\", state=\"active\"})",
          "legendFormat": "Activas"
        }
      ]
    },
    {
      "id": 5,
      "title": "Conexiones activas — PostgreSQL Movimientos",
      "type": "stat",
      "gridPos": { "x": 16, "y": 12, "w": 4, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-sispardt" },
          "expr": "sum(pg_stat_activity_count{job=\"postgres-movimientos\", state=\"active\"})",
          "legendFormat": "Activas"
        }
      ]
    },
    {
      "id": 6,
      "title": "Errores 4xx/5xx — Traefik",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 24, "w": 24, "h": 6 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus-sispardt" },
          "expr": "sum(rate(traefik_service_requests_total{code=~\"4..|5..\"}[5m])) by (code)",
          "legendFormat": "HTTP {{code}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "thresholdsStyle": { "mode": "line" } },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green" }, { "color": "red", "value": 1 }]
          }
        }
      }
    }
  ]
}
