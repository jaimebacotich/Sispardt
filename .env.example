# ============================================================
# SISPARDT - Variables de Entorno
# Copiar a .env y completar con valores reales.
# NUNCA commitear el archivo .env al repositorio.
# ============================================================

# ----------------------------------------------------------
# INFRAESTRUCTURA - Cambiar según donde corra Docker
#   localhost         → desarrollo en la misma máquina
#   192.168.x.x       → otra PC en la red local
#   sispardt.com      → producción con dominio
#
#   APP_PORT=3100     → desarrollo
#   APP_PORT=80       → producción (sin puerto en la URL)
# ----------------------------------------------------------
APP_HOST=localhost
APP_PORT=3100

# ----------------------------------------------------------
# PostgreSQL - Usuario superadmin compartido entre instancias
# ----------------------------------------------------------
POSTGRES_USER=postgres

# Passwords de las instancias de BD (superusuario)
POSTGRES_PASSWORD_EST=tu_password_establecimientos_aqui
POSTGRES_PASSWORD_MOV=tu_password_movimientos_aqui
POSTGRES_PASSWORD_KC=tu_password_keycloak_aqui

# Puertos expuestos en localhost
PORT_DB_EST=5432
PORT_DB_MOV=5433
PORT_DB_KC=5434

# ----------------------------------------------------------
# Passwords de usuarios de aplicacion
# (se crean en los scripts de init)
# ----------------------------------------------------------
# Usuarios de Keycloak (end-users del sistema web)
APP_PASS_ADMIN=cambia_esto_min8chars
APP_PASS_RESP_REG=cambia_esto_min8chars
APP_PASS_TEC_REG=cambia_esto_min8chars
APP_PASS_RECEP=cambia_esto_min8chars
APP_PASS_ESTAD=cambia_esto_min8chars
# Usuarios de BD (conexión PostgreSQL)
APP_PASS_DEBEZIUM=cambia_esto_min8chars
APP_PASS_KAFKA=cambia_esto_min8chars

# ----------------------------------------------------------
# Carga de datos de prueba (solo dev/test)
# true = carga 05-datos-prueba.sql en ambas BDs
# false = solo esquema + catalogos (produccion)
# ----------------------------------------------------------
LOAD_TEST_DATA=true

# ----------------------------------------------------------
# Keycloak 26.4
# ----------------------------------------------------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=cambia_esto_min8chars
KC_HTTP_PORT=8080
KC_MANAGEMENT_PORT=9000

# Secrets de clientes confidenciales (service-to-service)
KC_SECRET_EST_SVC=cambia_esto_min32chars
KC_SECRET_MOV_SVC=cambia_esto_min32chars

# ----------------------------------------------------------
# NextAuth (frontend)
# Generar con: openssl rand -base64 32
# ----------------------------------------------------------
NEXTAUTH_SECRET=genera_un_secreto_aleatorio_min32chars

# ----------------------------------------------------------
# API Gateway (Traefik)
# ----------------------------------------------------------
TRAEFIK_HTTP_PORT=80
TRAEFIK_DASHBOARD_PORT=8090

# ----------------------------------------------------------
# JWT Validation
# ----------------------------------------------------------
KEYCLOAK_JWKS_URL_INTERNAL=http://keycloak:8080/realms/sispardt/protocol/openid-connect/certs
# Dev: http://localhost:8080/realms/sispardt
# Prod: https://auth.tudominio.com/realms/sispardt
KEYCLOAK_ISSUER=http://localhost:8080/realms/sispardt

# ----------------------------------------------------------
# Microservicios
# ----------------------------------------------------------
LOG_LEVEL=info    # debug | info | warn | error
ENV=development   # development | production

# ----------------------------------------------------------
# Kafka + Debezium
# ----------------------------------------------------------
KAFKA_EXTERNAL_PORT=9094
KAFKA_UI_PORT=8091
DEBEZIUM_PORT=8083

# ----------------------------------------------------------
# Monitoreo (Prometheus + Grafana)
# ----------------------------------------------------------
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=cambia_esto

# ----------------------------------------------------------
# Entorno
# ----------------------------------------------------------
TZ=America/La_Paz
