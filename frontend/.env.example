# SISPARDT Frontend — Variables de entorno
# Copiar a .env.local y completar con valores reales

# NextAuth
NEXTAUTH_URL=http://localhost:3100
NEXTAUTH_SECRET=genera-un-secret-seguro-aqui

# Keycloak OIDC
AUTH_KEYCLOAK_ID=sispardt-web
AUTH_KEYCLOAK_SECRET=
AUTH_KEYCLOAK_ISSUER=http://localhost:8080/realms/sispardt

# API Gateway (Traefik) — URL pública accesible desde el browser
NEXT_PUBLIC_API_BASE_URL=http://localhost:80

# URLs internas (server-side Next.js dentro de Docker)
API_ESTABLECIMIENTOS_URL=http://traefik:80/api/establecimientos
API_MOVIMIENTOS_URL=http://traefik:80/api/movimientos

# Fecha de inicio de operaciones del sistema (primer día que debe tener cierre)
# Formato: YYYY-MM-DD
NEXT_PUBLIC_INICIO_SISTEMA=2026-03-01

# Geografía por defecto — Bolivia=1, Tarija=1
NEXT_PUBLIC_PAIS_DEFECTO=1
NEXT_PUBLIC_DIVISION_PRINCIPAL=1
